# Verification Service port
VERIFICATION_SERVER_PORT=8086

# Database konfiguracija
VERIFICATION_DB_HOST=localhost
VERIFICATION_DB_PORT=5438
VERIFICATION_DB_NAME=verificationdb
VERIFICATION_DB_USER=postgres
VERIFICATION_DB_PASSWORD=postgres
VERIFICATION_DB_EXTERNAL_PORT=5438
VERIFICATION_DB_INTERNAL_PORT=5432

# JWT
JWT_SECRET=your_jwt_secret_here

# TOTP (WP-6, Celina 2.1) — AES-256 kljuc za enkripciju per-session TOTP
# secret-a u koloni verification_sessions.totp_secret (32 bajta Base64).
# Generisi sa: openssl rand -base64 32. NE deli se sa JWT_SECRET.
VERIFICATION_TOTP_ENCRYPTION_KEY=VG90cERldk9ubHlBRVMyNTZLZXkzMkJ5dGVzISEhNDI=

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_USERNAME=rabbit
RABBITMQ_PASSWORD=rabbit

# Notification Service
NOTIFICATION_QUEUE=notification-service-queue
NOTIFICATION_EXCHANGE=employee.events
NOTIFICATION_ROUTING_KEY=employee.#
